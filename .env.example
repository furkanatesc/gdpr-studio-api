# Yerel geliştirme örneği — kopyala: cp .env.example .env
DATABASE_URL=postgresql+psycopg://kvkk:kvkk@localhost:5432/kvkk
REDIS_URL=redis://localhost:6379/0

# Managed mod (web) sunucu anahtarı. Boşsa yalnızca BYOK (X-Anthropic-Key) çalışır.
MANAGED_ANTHROPIC_API_KEY=

DEFAULT_MODEL=claude-sonnet-4-6
ALLOWED_ORIGINS=http://localhost:3000
ENVIRONMENT=development
